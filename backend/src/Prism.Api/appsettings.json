{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Database": {
    "ConnectionString": "Host=localhost;Port=5438;Database=prism;Username=postgres;Password=postgres"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5438;Database=prism;Username=postgres;Password=postgres"
  },
  "Cache": {
    "Provider": "InMemory"
  },
  "JobQueue": {
    "Provider": "InMemory"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Storage": {
    "Provider": "Local",
    "Local": {
      "BasePath": "./data/storage"
    }
  },
  "Auth": {
    "Provider": "None"
  },
  "InferenceProviders": [],
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  }
}
